<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox spacing="10" alignment="TOP_CENTER" VBox.vgrow="ALWAYS" style="-fx-padding: 15;"
      xmlns="http://javafx.com"
      xmlns:fx="http://javafx.com"
      fx:controller="ru.maximys.nexusai.ui.controller.ChatController">
    <!-- Область диалога -->
    <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                styleClass="edge-to-edge" style="-fx-background-color: transparent;">
        <VBox fx:id="messageContainer" spacing="15" style="-fx-padding: 10;">
            <!-- Здесь будут появляться сообщения -->
            <Label text="Nexus AI: Привет! Чем я могу помочь?" styleClass="text-muted"/>
        </VBox>
    </ScrollPane>

    <!-- Поле ввода внизу -->
    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="userMessageField"
                   onAction="#onSendMessage"
                   HBox.hgrow="ALWAYS"
                   promptText="Напишите запрос..."
                   styleClass="large"/>
        <Button text="Отправить" onAction="#onSendMessage" styleClass="accent, large"/>
    </HBox>
</VBox>

