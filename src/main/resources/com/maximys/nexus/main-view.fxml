<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import atlantafx.base.controls.Spacer?>

<!-- КОРНЕВОЙ УЗЕЛ ИЗМЕНЕН НА STACKPANE ДЛЯ ПЕРЕКРЫТИЯ ВСЕЙ ПЛОЩАДИ ОКНА -->
<StackPane xmlns="http://javafx.com"
           xmlns:fx="http://javafx.com"
           fx:controller="com.maximys.nexus.client.ui.controller.MainController"
           stylesheets="@/css/mainStyle.css"
           prefWidth="1000"
           prefHeight="600">

    <!-- СЛОЙ 1: ОСНОВНОЙ ИНТЕРФЕЙС ПРИЛОЖЕНИЯ (ОБЕРНУТ В VBOX С ИДЕНТИФИКАТОРОМ ДЛЯ BLUR ЭФФЕКТА) -->
    <VBox fx:id="mainContainer" spacing="0">

        <!-- Заголовок (TitleBar) -->
        <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="0" prefHeight="38"
              style="-fx-background-color: -color-bg-subtle; -fx-padding: 0 0 0 15;">
            <Label text="Nexus" styleClass="title-4" />
            <Pane HBox.hgrow="ALWAYS" />
            <Button fx:id="profileButton" text="Profile"
                    styleClass="flat" style="-fx-text-fill: -color-accent-fg;"/>
            <Button fx:id="minimizeButton" text="—" onAction="#onMinimizeClick" styleClass="window-button" />
            <Button fx:id="maximizeButton" text="🗖" onAction="#onMaximizeClick" styleClass="window-button" />
            <Button fx:id="closeButton" text="✕" onAction="#onCloseClick" styleClass="window-button-close" />
        </HBox>

        <!-- Основная рабочая область -->
        <HBox VBox.vgrow="ALWAYS">
            <!-- Сайдбар -->
            <VBox prefWidth="200" spacing="5" style="-fx-background-color: -color-bg-inset; -fx-padding: 10;">
                <Button fx:id="textButton" text="Text" onAction="#onChatButtonClick"
                        maxWidth="Infinity" alignment="BASELINE_LEFT" styleClass="flat" />
                <Button fx:id="imageButton" text="Image" onAction="#onImageButtonClick"
                        maxWidth="Infinity" alignment="BASELINE_LEFT" styleClass="flat" />
                <Button fx:id="videoButton" text="Video"
                        maxWidth="Infinity" alignment="BASELINE_LEFT" styleClass="flat" />
                <Button fx:id="audioButton" text="Audio"
                        maxWidth="Infinity" alignment="BASELINE_LEFT" styleClass="flat" />
                <Button fx:id="modelsButton" text="Models" onAction="#onModelsButtonClick"
                        maxWidth="Infinity" alignment="BASELINE_LEFT" styleClass="flat" />
                <Spacer VBox.vgrow="ALWAYS"/>
                <Separator />
                <Button fx:id="settingsButton" text="Settings" onAction="#onSettingButtonClick"
                        maxWidth="Infinity" alignment="BASELINE_LEFT" styleClass="flat" />

                <!-- Кнопка обновления -->
                <Button fx:id="updateButton"
                        text="Update"
                        onAction="#onUpdateClick"
                        visible="false"
                        managed="false"
                        maxWidth="Infinity"
                        alignment="BASELINE_LEFT"
                        styleClass="flat"
                        style="-fx-text-fill: -color-warning-fg; -fx-font-weight: bold;"
                />
                <!-- Метка версии -->
                <Label fx:id="versionLabel" style="-fx-font-size: 10; -fx-opacity: 0.4; -fx-padding: 5 0 0 5;"/>
            </VBox>

            <!-- Область контента -->
            <StackPane fx:id="contentArea" HBox.hgrow="ALWAYS" style="-fx-background-color: -color-bg-default; -fx-padding: 20;">
                <VBox alignment="CENTER" spacing="20">
                    <Label fx:id="welcomeLabel" text="Select generation type" styleClass="text-muted" />
                </VBox>
            </StackPane>
        </HBox>
    </VBox>

    <StackPane fx:id="updateOverlay" visible="false" managed="false"
               style="-fx-background-color: rgba(10, 10, 10, 0.7); -fx-alignment: center;">

        <!-- Карточка обновления по центру экрана -->
        <VBox maxWidth="520.0" maxHeight="420.0" spacing="16.0"
              styleClass="card"
              style="-fx-background-color: -color-bg-overlay; -fx-padding: 24; -fx-background-radius: 12; -fx-border-color: -color-border-default; -fx-border-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 15, 0, 0, 6);">

            <!-- Базовый размер заголовка увеличен до 18px -->
            <Label fx:id="modalTitleLabel" text="What's new in version {0}:"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -color-fg-default;"/>

            <!-- TextArea: Базовый шрифт увеличен до 14px, убран жесткий шрифт Segoe UI, чтобы AtlantaFX масштабировала его нативно -->
            <TextArea fx:id="changelogTextArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"
                      style="-fx-font-size: 14px; -fx-line-spacing: 3px;"/>

            <HBox spacing="12.0" alignment="CENTER" maxWidth="Infinity">
                <Button fx:id="closeModalButton"
                        text="Later"
                        onAction="#onCloseModalClick"
                        maxWidth="Infinity"
                        prefHeight="38.0"
                        HBox.hgrow="ALWAYS" />
                <Button fx:id="installUpdateButton"
                        text="Install"
                        onAction="#onInstallUpdateClick"
                        styleClass="button-primary"
                        maxWidth="Infinity"
                        prefHeight="38.0"
                        HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>
    </StackPane>

</StackPane>
